<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <link rel="stylesheet" href="/css/style.css" type="text/css">
</head>
<body>
  <div id="background">
    <div id="page">
      {{> header}}
      <div id="contents">
        <div class="box">
          <div>
            <div class="body">
              <h1>Rooms</h1>
              <ul id="rooms">
                {{#each rooms}}
                <li>
                  <a href="/rooms"><img src="/{{image}}" alt="Img"></a>
                  <h2><a href="/rooms">{{name}}</a></h2>
                  <p>{{description}}</p>
                  <span class="rate">Rate: {{rate}}</span>
                </li>
                {{/each}}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    {{> footer}}
  </div>
</body>
</html>